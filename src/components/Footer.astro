---
const social = [
	{ href: 'https://instagram.com/rionegiallo', label: 'Instagram' },
	{ href: 'https://facebook.com/rionegiallo', label: 'Facebook' },
];
---

<footer class="bg-amaranto-950 text-giallo-50 mt-16 border-t-4 border-giallo-500">
	<div class="max-w-5xl mx-auto px-4 py-12 grid gap-8 sm:grid-cols-3">
		<div>
			<p class="font-display text-2xl uppercase text-giallo-400">Rione Giallo</p>
			<p class="text-sm text-giallo-100/80 mt-3">Via Bondiolo 85<br />Faenza (RA)</p>
			<p class="text-xs text-amaranto-300 mt-3 uppercase tracking-widest">Porta Ponte</p>
		</div>
		<div>
			<p class="font-semibold text-sm uppercase tracking-widest text-giallo-400">Seguici</p>
			<ul class="mt-3 space-y-1.5 text-sm">
				{social.map((s) => (
					<li><a href={s.href} class="text-giallo-100 hover:text-white hover:underline">{s.label}</a></li>
				))}
			</ul>
		</div>
		<div>
			<p class="font-semibold text-sm uppercase tracking-widest text-giallo-400">Contatti</p>
			<ul class="mt-3 space-y-1.5 text-sm">
				<li><a href="/contatti" class="text-giallo-100 hover:text-white hover:underline">Scrivici su WhatsApp</a></li>
				<li><a href="/eventi" class="text-giallo-100 hover:text-white hover:underline">Prossimi eventi</a></li>
			</ul>
		</div>
	</div>
	<div class="border-t border-amaranto-800 py-4 text-center text-xs text-giallo-200/70">
		<p>&copy; {new Date().getFullYear()} Rione Giallo — Faenza</p>
	</div>
</footer>