---
interface Props {
	titolo: string;
	sottotitolo?: string;
}
const { titolo, sottotitolo } = Astro.props;
---

<article class="max-w-3xl mx-auto px-4 py-12">
	<header class="border-b border-yellow-200 pb-6 mb-8">
		<h1 class="text-4xl sm:text-5xl font-bold text-yellow-500">{titolo}</h1>
		{sottotitolo && <p class="mt-3 text-lg text-gray-600">{sottotitolo}</p>}
	</header>

	<div class="prose prose-yellow max-w-none">
		<slot />
	</div>
</article>