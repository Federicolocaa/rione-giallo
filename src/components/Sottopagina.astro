---
interface Props {
	titolo: string;
	sottotitolo?: string;
}
const { titolo, sottotitolo } = Astro.props;
---

<article class="max-w-3xl mx-auto px-4 py-12">
	<header class="border-b-4 border-giallo-500 pb-6 mb-8">
		<h1 class="font-display text-4xl sm:text-6xl uppercase text-amaranto-800">{titolo}</h1>
		{sottotitolo && <p class="mt-3 text-lg text-amaranto-600">{sottotitolo}</p>}
	</header>

	<div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:uppercase prose-headings:text-giallo-600 prose-a:text-amaranto-700">
		<slot />
	</div>
</article>