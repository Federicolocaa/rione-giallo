---
const utility = [
	{ href: '/', label: 'Home' },
	{ href: '/giugno', label: 'Giugno' },
	{ href: '/news', label: 'News' },
	{ href: '/albo-doro', label: "Albod'Oro" },
	{ href: '/contatti', label: 'Contatti' },
];

const aree = [
	{
		label: 'Palio',
		voci: [
			{ href: '/palio', label: 'Palio del Niballo' },
			{ href: '/palio', label: 'Le scuderie' },
			{ href: '/palio', label: 'Storia del palio' },
			{ href: '/news', label: 'News' },
		],
	},
	{
		label: 'Piazza',
		voci: [
			{ href: '/piazza', label: 'Gruppo storico' },
			{ href: '/piazza', label: 'Torneo alfieri e musici' },
			{ href: '/piazza', label: 'Nott de Bisó' },
			{ href: '/albo-doro', label: "Albo d'oro" },
		],
	},
	{
		label: 'Via Bondiolo',
		voci: [
			{ href: '/via-bondiolo', label: 'La sede' },
			{ href: '/via-bondiolo', label: 'Il quartiere' },
			{ href: '/via-bondiolo', label: 'Sala delle bandiere' },
			{ href: '/via-bondiolo', label: 'Soci' },
			{ href: '/via-bondiolo', label: 'Eventi' },
		],
	},
	{
		label: 'Storia',
		voci: [
			{ href: '/storia', label: 'Costumi' },
			{ href: '/storia', label: 'La sfilata' },
			{ href: '/storia', label: 'Le dame' },
			{ href: '/storia', label: 'Rievocazione' },
		],
	},
	{
		label: 'Chi siamo',
		voci: [
			{ href: '/chi-siamo', label: 'Chi siamo' },
			{ href: '/chi-siamo', label: 'Collaborazioni' },
			{ href: '/contatti', label: 'Contatti' },
			{ href: '/chi-siamo', label: 'Ringraziamenti' },
		],
	},
];
---

<header class="bg-yellow-500 text-yellow-950 relative z-40">
	<div class="max-w-6xl mx-auto flex items-center justify-between px-4 py-3">
		<button id="menu-open" aria-label="Apri menu" class="p-1">
			<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/>
			</svg>
		</button>
		<ul class="flex gap-5 text-sm font-medium">
			{utility.map((l) => (
				<li><a href={l.href} class="hover:underline">{l.label}</a></li>
			))}
		</ul>
	</div>
</header>

<div id="menu-overlay" class="fixed inset-0 z-50 bg-yellow-950 text-yellow-50 hidden overflow-y-auto">
	<div class="max-w-6xl mx-auto px-6 py-8">
		<button id="menu-close" aria-label="Chiudi menu" class="absolute top-6 right-6 p-1">
			<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/>
			</svg>
		</button>

		<h2 class="text-6xl font-bold mb-8">MENU</h2>
		<a href="/" class="block text-lg font-semibold mb-6 hover:underline">HOME</a>

		<div class="space-y-3 max-w-md">
			{aree.map((area) => (
				<div class="area">
					<button class="area-toggle w-full flex items-center justify-between px-5 py-4 bg-yellow-500 text-yellow-950 rounded-full font-bold text-lg">
						{area.label}
						<svg class="chevron w-5 h-5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</button>
					<ul class="area-voci hidden pl-5 py-2 space-y-1">
						{area.voci.map((voce) => (
							<li><a href={voce.href} class="block py-1.5 text-yellow-100 hover:text-white hover:underline">{voce.label}</a></li>
						))}
					</ul>
				</div>
			))}
		</div>

		<div class="mt-8 space-y-4 max-w-md">
			<a href="/giugno" class="block text-lg font-semibold hover:underline">GIUGNO</a>
			<a href="/news" class="block text-lg font-semibold hover:underline">NEWS & EVENTI</a>
		</div>
	</div>
</div>

<script>
	const overlay = document.getElementById('menu-overlay');
	document.getElementById('menu-open')?.addEventListener('click', () => {
		overlay?.classList.remove('hidden');
		document.body.style.overflow = 'hidden';
	});
	document.getElementById('menu-close')?.addEventListener('click', () => {
		overlay?.classList.add('hidden');
		document.body.style.overflow = '';
	});
	document.querySelectorAll('.area-toggle').forEach((btn) => {
		btn.addEventListener('click', () => {
			const voci = btn.nextElementSibling;
			const chevron = btn.querySelector('.chevron');
			voci?.classList.toggle('hidden');
			chevron?.classList.toggle('rotate-180');
		});
	});
</script>