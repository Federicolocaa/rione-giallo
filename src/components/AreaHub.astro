---
interface Props {
	titolo: string;
	sottopagine: string[];
}
const { titolo, sottopagine } = Astro.props;
---

<div class="px-4 py-12 max-w-4xl mx-auto">
	<h1 class="text-5xl font-bold text-yellow-500">{titolo}</h1>
	<ul class="mt-8 grid gap-4 sm:grid-cols-2">
		{sottopagine.map((s) => (
			<li class="border border-yellow-200 rounded-lg px-5 py-4 hover:bg-yellow-50 transition">
				<span class="font-medium text-yellow-950">{s}</span>
				<p class="text-sm text-gray-500 mt-1">Contenuto in arrivo</p>
			</li>
		))}
	</ul>
</div>