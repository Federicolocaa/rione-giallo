import Layout from '../../layouts/Layout.astro';
import Sottopagina from '../../components/Sottopagina.astro';
---

<Layout title="Gruppo storico — Rione Giallo">
	<Sottopagina titolo="Il gruppo storico" sottotitolo="Sbandieratori, musici e figuranti del Rione Giallo">
		<p>
			Il Gruppo Sbandieratori e Musici rappresenta una delle anime più vive del Rione Giallo.
			Aderisce alla Federazione Italiana Sbandieratori, della quale Faenza è socia fondatrice,
			e partecipa sia alle gare faentine del mese di giugno sia alle competizioni nazionali.
			Il gruppo è inoltre chiamato con regolarità a esibirsi in Italia e all'estero, portando
			l'arte della bandiera faentina in contesti prestigiosi.
		</p>

		<h2>Gli sbandieratori</h2>
		<p>
			Gli alfieri del rione si allenano durante tutto l'anno per affinare tecnica, resistenza
			fisica e sincronizzazione. Le bandiere, con asta in fibra di carbonio, misurano circa
			170 centimetri e portano un drappo di almeno 130 per 130 centimetri con i colori e le
			insegne del rione. L'esercizio richiede precisione assoluta: portamento, sincronismo e
			pochi errori nel maneggio sono gli aspetti valutati dai giudici della Federazione.
		</p>

		<h2>I musici</h2>
		<p>
			Chiarine e tamburi accompagnano il corteo storico e le esibizioni degli sbandieratori,
			scandendo il ritmo della marcia del rione. La componente musicale è parte integrante
			dello spettacolo: senza il suono di tamburi e chiarine, le figure delle bandiere
			perderebbero la loro cadenza solenne.
		</p>

		<h2>Il vivaio</h2>
		<p>
			Del gruppo fanno parte anche le giovani leve, che con l'aiuto dei più esperti si
			preparano ai futuri impegni agonistici. Il Rione Giallo vanta storicamente un ottimo
			settore giovanile, capace di formare alfieri di valore nelle categorie Under 15 e
			Under 21, molti dei quali diventano protagonisti tra gli Assoluti.
		</p>
	</Sottopagina>
</Layout>