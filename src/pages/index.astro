---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const categorie = [
	{
		parola: 'PALIO',
		video: '/video/palio.mp4',
		pillole: [
			{ href: '/palio/niballo', label: 'Palio del Niballo' },
			{ href: '/palio/scuderie', label: 'Le scuderie' },
			{ href: '/palio/storia', label: 'Storia del palio' },
			{ href: '/giugno', label: 'Countdown' },
		],
	},
	{
		parola: 'PIAZZA',
		video: '/video/piazza.mp4',
		pillole: [
			{ href: '/piazza/gruppo-storico', label: 'Gruppo storico' },
			{ href: '/piazza/torneo', label: 'Torneo alfieri e musici' },
			{ href: '/piazza/nott-de-biso', label: 'Nott de Bisó' },
			{ href: '/albo-doro', label: "Albo d'oro" },
		],
	},
	{
		parola: 'SEDE',
		video: '/video/sede.mp4',
		pillole: [
			{ href: '/via-bondiolo/sede', label: 'La sede' },
			{ href: '/via-bondiolo/consiglio', label: 'Consiglio direttivo' },
			{ href: '/via-bondiolo/soci', label: 'Soci' },
			{ href: '/eventi', label: 'Eventi' },
		],
	},
	{
		parola: 'STORIA',
		video: '/video/storia.mp4',
		pillole: [
			{ href: '/storia/costumi', label: 'Costumi' },
			{ href: '/storia/sfilata', label: 'La sfilata' },
			{ href: '/storia/dame', label: 'Le dame' },
			{ href: '/storia/rievocazione', label: 'Rievocazione' },
		],
	},
];

const ultimeNews = (await getCollection('news'))
	.sort((a, b) => b.data.data.valueOf() - a.data.data.valueOf())
	.slice(0, 3);
---

<Layout title="Rione Giallo">
	<section id="hero" class="relative h-[calc(100vh-64px)] overflow-hidden flex items-center select-none">
		<video id="hero-video" class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline>
			<source src="/video/palio.mp4" type="video/mp4" />
		</video>
		<div class="absolute inset-0 bg-amaranto-950/50"></div>
		<div class="absolute inset-0 bg-gradient-to-b from-giallo-500/10 to-amaranto-950/70"></div>

		<div class="relative z-10 px-6 sm:px-12 max-w-6xl w-full">
			<h1 class="font-display text-6xl sm:text-8xl leading-[0.95] tracking-tight uppercase drop-shadow-lg">
				<span class="block text-white">R<img src="/torre.svg" alt="i" class="inline-block h-[0.9em] w-auto align-[-0.14em] mx-[0.04em]" />one</span>
				<span class="block text-white">Giallo</span>
				<span class="block text-white">
					è <span id="parola-rotante" class="text-giallo-400 transition-opacity duration-300">PALIO</span>
				</span>
			</h1>

			<div id="pillole" class="mt-8 flex flex-wrap gap-3 max-w-2xl transition-opacity duration-300">
				{categorie[0].pillole.map((p) => (
					<a href={p.href} class="px-5 py-2.5 rounded-full border-2 border-giallo-400 text-white font-medium text-sm sm:text-base hover:bg-giallo-400 hover:text-amaranto-950 transition backdrop-blur-sm">
						{p.label}
					</a>
				))}
			</div>
		</div>

		<div class="absolute bottom-8 left-0 right-0 z-10 flex flex-col items-center gap-3">
			<div id="dots" class="flex gap-2">
				{categorie.map((_, idx) => (
					<span data-dot={idx} class={`w-2.5 h-2.5 rounded-full transition ${idx === 0 ? 'bg-giallo-400' : 'bg-white/40'}`}></span>
				))}
			</div>
			<svg class="w-7 h-7 text-giallo-400 drop-shadow animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</div>
	</section>

	<!-- CHI SIAMO -->
	<section class="max-w-4xl mx-auto px-6 py-20 text-center">
		<h2 class="font-display text-4xl sm:text-5xl uppercase text-amaranto-800">Il rione di Porta Ponte</h2>
		<p class="mt-6 text-lg text-gray-700 leading-relaxed">
			Il Rione Giallo Galeotto Manfredi è una delle cinque contrade che animano il Niballo,
			Palio di Faenza. Legato al casato dei Manfredi, porta i colori di Porta Ponte in pista,
			con i suoi cavalieri, e in piazza, con gli sbandieratori e i musici.
		</p>
		<a href="/storia" class="inline-block mt-8 px-6 py-3 rounded-full bg-amaranto-700 text-white font-semibold hover:bg-amaranto-800 transition">
			Scopri la nostra storia
		</a>
	</section>

	<!-- ULTIME NEWS -->
	{ultimeNews.length > 0 && (
		<section class="bg-giallo-50 py-20">
			<div class="max-w-5xl mx-auto px-6">
				<div class="flex items-baseline justify-between flex-wrap gap-2">
					<h2 class="font-display text-4xl uppercase text-amaranto-800">Ultime news</h2>
					<a href="/news" class="text-sm font-semibold text-amaranto-700 hover:underline">Tutte le news →</a>
				</div>
				<div class="mt-10 grid gap-6 sm:grid-cols-3">
					{ultimeNews.map((a) => (
						<a href={`/news/${a.id}`} class="group block bg-white rounded-2xl p-6 border-l-4 border-amaranto-600 hover:shadow-lg transition">
							<p class="text-xs font-semibold text-amaranto-700">
								{a.data.data.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
							</p>
							<h3 class="font-display text-lg uppercase text-giallo-700 group-hover:text-giallo-800 mt-2">{a.data.titolo}</h3>
							<p class="text-sm text-gray-600 mt-2">{a.data.sommario}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- SOCIAL / UNISCITI -->
	<section class="py-20">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<h2 class="font-display text-4xl uppercase text-amaranto-800">Unisciti al rione</h2>
			<p class="mt-4 text-gray-700 max-w-xl mx-auto">
				Vuoi sbandierare, suonare o semplicemente vivere la vita del rione? Ti aspettiamo.
			</p>
			<div class="mt-8 flex flex-wrap justify-center gap-4">
				<a href="/contatti" class="px-6 py-3 rounded-full bg-amaranto-700 text-white font-semibold hover:bg-amaranto-800 transition">Contattaci</a>
				<a href="https://instagram.com/rionegiallo" target="_blank" rel="noopener" class="px-6 py-3 rounded-full border-2 border-amaranto-700 text-amaranto-700 font-semibold hover:bg-amaranto-700 hover:text-white transition">Seguici su Instagram</a>
			</div>
		</div>
	</section>

	<script define:vars={{ categorie }}>
		const elParola = document.getElementById('parola-rotante');
		const elPillole = document.getElementById('pillole');
		const elVideo = document.getElementById('hero-video');
		const dots = document.querySelectorAll('[data-dot]');
		let i = 0;
		let inCorso = false;
		let autoTimer = null;

		function render(indice) {
			elParola.style.opacity = '0';
			elPillole.style.opacity = '0';
			setTimeout(() => {
				const cat = categorie[indice];
				elParola.textContent = cat.parola;
				elPillole.innerHTML = cat.pillole
					.map(
						(p) =>
							`<a href="${p.href}" class="px-5 py-2.5 rounded-full border-2 border-giallo-400 text-white font-medium text-sm sm:text-base hover:bg-giallo-400 hover:text-amaranto-950 transition backdrop-blur-sm">${p.label}</a>`
					)
					.join('');
				const src = elVideo.querySelector('source');
				if (src.getAttribute('src') !== cat.video) {
					src.setAttribute('src', cat.video);
					elVideo.load();
				}
				dots.forEach((d, idx) => {
					d.classList.toggle('bg-giallo-400', idx === indice);
					d.classList.toggle('bg-white/40', idx !== indice);
				});
				elParola.style.opacity = '1';
				elPillole.style.opacity = '1';
			}, 300);
		}

		function vaiA(indice) {
			if (inCorso) return;
			inCorso = true;
			i = indice;
			render(i);
			setTimeout(() => { inCorso = false; }, 800);
		}

		function cambia(direzione) {
			const nuovo = i + direzione;
			if (nuovo < 0 || nuovo >= categorie.length) return false;
			vaiA(nuovo);
			return true;
		}

		// --- Slide automatico ogni 5 secondi (ciclico) ---
		function avviaAuto() {
			if (autoTimer) return;
			autoTimer = setInterval(() => {
				if (window.scrollY < 10) {
					const prossimo = (i + 1) % categorie.length;
					vaiA(prossimo);
				}
			}, 5000);
		}

		function fermaAuto() {
			if (autoTimer) {
				clearInterval(autoTimer);
				autoTimer = null;
			}
		}

		avviaAuto();

		// --- Interazione manuale: ferma l'automatico ---
		window.addEventListener('wheel', (e) => {
			if (window.scrollY < 10) {
				if (e.deltaY > 10 && i < categorie.length - 1) {
					e.preventDefault();
					fermaAuto();
					cambia(1);
				} else if (e.deltaY < -10 && i > 0) {
					e.preventDefault();
					fermaAuto();
					cambia(-1);
				}
			}
		}, { passive: false });

		let touchStartY = 0;
		window.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: true });
		window.addEventListener('touchend', (e) => {
			if (window.scrollY >= 10) return;
			const diff = touchStartY - e.changedTouches[0].clientY;
			if (diff > 40 && i < categorie.length - 1) { fermaAuto(); cambia(1); }
			else if (diff < -40 && i > 0) { fermaAuto(); cambia(-1); }
		}, { passive: true });

		// Click sui pallini: vai a quella categoria e ferma l'automatico
		dots.forEach((d) => {
			d.style.cursor = 'pointer';
			d.addEventListener('click', () => {
				fermaAuto();
				vaiA(Number(d.dataset.dot));
			});
		});
	</script>
</Layout>