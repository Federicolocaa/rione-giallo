import Layout from '../../layouts/Layout.astro';
import Sottopagina from '../../components/Sottopagina.astro';
---

<Layout title="Rievocazione — Rione Giallo">
	<Sottopagina titolo="La rievocazione" sottotitolo="La signoria dei Manfredi rivive ogni anno">
		<p>
			La rievocazione storica del Palio di Faenza prende in considerazione l'arco temporale dello
			sviluppo della signoria dei Manfredi, dal 1303 al 1501, fino all'assedio e alla conquista
			della città. Non si tratta di una semplice gara, ma del costante rinnovo di una tradizione
			che affonda le proprie radici nella Faenza medievale e rinascimentale.
		</p>

		<h2>Porta Ponte e i Manfredi</h2>
		<p>
			Il Rione Giallo è il rione di Porta Ponte, un tempo possente fortificazione alta quasi
			trenta metri che accoglieva chi giungeva dal Borgo, demolita a metà dell'Ottocento. Nello
			stemma rionale la torre è cinta da due ordini di merli guelfi e fasciata di vermiglio,
			simboli che richiamano il legame con i Manfredi, signori di Faenza e sostenitori del
			pontefice.
		</p>

		<h2>Una tradizione viva</h2>
		<p>
			La rievocazione non è un esercizio nostalgico, ma un patrimonio vissuto e tramandato dai
			rionali di ogni generazione. Attraverso i costumi, la sfilata, le dame e le gare, il Rione
			Giallo mantiene viva la memoria di un'epoca e la trasmette alla città e ai suoi visitatori,
			rinnovando ogni anno l'orgoglio di appartenere a Porta Ponte.
		</p>
	</Sottopagina>
</Layout>