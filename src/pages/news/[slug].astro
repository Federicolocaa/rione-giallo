---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
    const articoli = await getCollection('news');
    return articoli.map((a) => ({
        // Modificato a.slug in a.id
        params: { slug: a.id },
        props: { articolo: a },
    }));
}

type Props = { articolo: CollectionEntry<'news'> };
const { articolo } = Astro.props as Props;

// Nuova API di Astro v6 per estrarre il Content
const { Content } = await render(articolo);
---

<Layout title={`${articolo.data.titolo} — Rione Giallo`}>
    <article class="max-w-3xl mx-auto px-6 py-12">
        <a href="/news" class="text-sm text-amaranto-700 hover:underline">← Tutte le news</a>
        <header class="border-b-4 border-giallo-500 pb-6 mb-8 mt-4">
            <p class="text-sm font-semibold text-amaranto-700">
                {articolo.data.data.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
            <h1 class="font-display text-4xl sm:text-5xl uppercase text-amaranto-800 mt-2">{articolo.data.titolo}</h1>
        </header>
        <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:uppercase prose-headings:text-giallo-600 prose-a:text-amaranto-700">
            <Content />
        </div>
    </article>
</Layout>