---
import Layout from '../layouts/Layout.astro';

const wa = 'https://wa.me/393273621866';
const ig = 'https://instagram.com/rionegiallo';
const fb = 'https://facebook.com/rionegiallo';
const email = 'info@rionegiallo.it';
---

<Layout title="Contatti — Rione Giallo">
	<div class="max-w-3xl mx-auto px-6 py-12">
		<h1 class="font-display text-5xl sm:text-6xl uppercase text-amaranto-800">Contatti</h1>
		<p class="mt-4 text-lg text-gray-700">
			Vuoi iniziare a sbandierare o suonare con noi? Scrivici direttamente su WhatsApp,
			oppure seguici sui social.
		</p>

		<a href={wa} target="_blank" rel="noopener" class="mt-8 flex items-center gap-4 bg-green-600 text-white rounded-2xl p-6 hover:bg-green-700 transition">
			<svg class="w-10 h-10 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 00-8.5 15.3L2 22l4.8-1.5A10 10 0 1012 2zm0 18a8 8 0 01-4.1-1.1l-.3-.2-2.8.9.9-2.7-.2-.3A8 8 0 1112 20zm4.4-5.6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.7.9-.3.2-.5.1a6.5 6.5 0 01-1.9-1.2 7.3 7.3 0 01-1.3-1.7c-.1-.2 0-.4.1-.5l.4-.4.2-.4a.5.5 0 000-.4l-.7-1.8c-.2-.5-.4-.4-.5-.4h-.5a.9.9 0 00-.7.3A2.8 2.8 0 006 9.3a4.9 4.9 0 001 2.6 11 11 0 004.3 3.8c.6.3 1.1.4 1.5.5a3.5 3.5 0 001.6.1c.5-.1 1.4-.6 1.6-1.1s.2-1 .1-1.1-.2-.2-.4-.3z"/></svg>
			<div>
				<p class="font-bold text-lg">Scrivici su WhatsApp</p>
				<p class="text-sm text-green-50">Inizia a sbandierare o suonare con il rione</p>
			</div>
		</a>

		<div class="mt-6 grid gap-4 sm:grid-cols-2">
			<a href={ig} target="_blank" rel="noopener" class="flex items-center gap-3 bg-giallo-50 border-l-4 border-amaranto-600 rounded-2xl p-5 hover:bg-giallo-100 transition">
				<svg class="w-8 h-8 text-amaranto-700 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
				<div>
					<span class="font-semibold text-amaranto-900 block">Instagram</span>
					<span class="text-xs text-gray-500">@rionegiallo</span>
				</div>
			</a>
			<a href={fb} target="_blank" rel="noopener" class="flex items-center gap-3 bg-giallo-50 border-l-4 border-amaranto-600 rounded-2xl p-5 hover:bg-giallo-100 transition">
				<svg class="w-8 h-8 text-amaranto-700 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 10-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0022 12z"/></svg>
				<div>
					<span class="font-semibold text-amaranto-900 block">Facebook</span>
					<span class="text-xs text-gray-500">Rione Giallo</span>
				</div>
			</a>
		</div>

		<div class="mt-10 text-gray-600 border-t border-giallo-200 pt-6 space-y-1">
			<p class="font-display text-lg uppercase text-giallo-700">Sede</p>
			<p>Via Bondiolo 85 — 48018 Faenza (RA)</p>
			<p>Tel. <a href="tel:+393273621866" class="text-amaranto-700 hover:underline">327 362 1866</a></p>
			<p>Email: <a href={`mailto:${email}`} class="text-amaranto-700 hover:underline">{email}</a></p>
		</div>
	</div>
</Layout>